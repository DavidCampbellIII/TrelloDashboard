{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "frontend/dist",
    "rootDir": "frontend/ts",
    "sourceMap": true
  },
  "include": ["frontend/ts/**/*.ts"],
  "exclude": ["node_modules"]
}
